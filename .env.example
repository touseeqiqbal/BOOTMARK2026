# BOOTMARK - Multi-Tenant SaaS Environment Template
# Copy this file to `.env` and fill in your values for local development.

# --- 🌐 General ---
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
SESSION_SECRET=your-secure-random-session-secret

# --- 🔥 Firebase Admin (Server-Side) ---
# Required for Auth & Firestore
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JSON String variant (Recommended for Render/Vercel)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# --- ⚛️ Firebase Web Config (Frontend) ---
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# --- ✉️ SMTP (Email Features) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM="BOOTMARK <noreply@yourdomain.com>"

# --- 💰 Payments & Accounting (Optional) ---
# Authorize.net
AUTHORIZE_API_LOGIN_ID=
AUTHORIZE_TRANSACTION_KEY=

# QuickBooks
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/api/quickbooks/callback

# --- 🛡️ Fallback Security ---
JWT_SECRET=your-jwt-fallback-secret-key
